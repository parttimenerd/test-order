[1.004, "o", "\u001b[1;33mACT 1: DEPENDENCY LEARNING\u001b[0m\r\nFirst, test-order learns which tests depend on which code.\r\n\r\n"]
[0.000, "o", "Cleaning and running learning phase...\r\n"]
