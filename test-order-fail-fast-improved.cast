[0.000, "o", "\r\n"]
[1.008, "o", "\u001b[1;33mACT 5: FAIL-FAST EXECUTION\u001b[0m\r\nRunning tests... StringUtilsTest runs FIRST and fails immediately.\r\n"]
[0.000, "o", "\r\n"]
