[1.009, "o", "\u001b[1;33mACT 2: BASELINE TEST ORDER\u001b[0m\r\nBefore code changes - tests ranked by speed alone.\r\n\r\n"]
[1.435, "o", "\r\n\u001b[0;32mScores: StringUtilsTest=1, CalculatorTest=0 (low scores)\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[1.006, "o", "\u001b[1;33mACT 3: BREAK THE CODE\u001b[0m\r\nChanging StringUtils.capitalize() to return empty string...\r\n\r\n"]
[0.010, "o", "Diff:\r\n"]
[0.024, "o", "diff --git a/test-order-example/src/main/java/com/example/app/StringUtils.java b/test-order-example/src/main/java/com/example/app/StringUtils.java\r\nindex b2fe0e5..c8fbad5 100644\r\n--- a/test-order-example/src/main/java/com/example/app/StringUtils.java\r\n+++ b/test-order-example/src/main/java/com/example/app/StringUtils.java\r\n@@ -18,6 +18,7 @@ public class StringUtils {\r\n \r\n     public String capitalize(String input) {\r\n         if (input == null || input.isEmpty()) return input;\r\n-        return Character.toUpperCase(input.charAt(0)) + input.substring(1);\r\n+        // BREAKING CHANGE: Returns empty string\r\n+        return \"\";\r\n     }\r\n-}\r\n\\ No newline at end of file\r\n+}\r\n"]
[0.001, "o", "\r\n"]
[1.006, "o", "\u001b[1;33mACT 4: INTELLIGENT REORDERING\u001b[0m\r\nNow test-order sees the changed class and recalculates priorities.\r\n"]
[0.000, "o", "\r\n"]
[1.108, "o", "\r\n"]
