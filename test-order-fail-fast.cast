[0.016, "o", "\u001b[0;34m=== Test-Order Fail-Fast Demo ===\u001b[0m\r\n\r\n\u001b[0;32mSCENE 1: Learning Dependencies\u001b[0m\r\n"]
[0.000, "o", "Cleaning old test-order data...\r\n"]
[0.009, "o", "Running full test suite with test-order instrumentation...\r\nThis creates a dependency graph of which tests exercise which classes.\r\n\r\n"]
[5.247, "o", "[10:36:37] [INFO] [test-order] change detection mode=auto changedClasses=0 changedTests=0\r\n"]
[0.706, "o", "[10:36:38] [INFO] [test-order] change detection mode=auto changedClasses=0 changedTests=0\r\n"]
[0.607, "o", "[10:36:39] [INFO] [test-order] change detection mode=auto changedClasses=0 changedTests=0\r\n"]
[0.104, "o", "\r\n"]
[1.008, "o", "\u001b[0;32mSCENE 2: Baseline Test Order\u001b[0m\r\nBefore any code changes, tests are ranked by execution speed.\r\n\r\n"]
[0.953, "o", "[INFO]   #    Test Class               Score  Deps  Fail  Changed Duration\r\n"]
[0.000, "o", "[INFO]   1.   c.e.app.StringUtilsTest      1                           7ms\r\n"]
[0.000, "o", "[INFO]   2.   c.e.app.CalculatorTest       0                          34ms\r\n"]
[0.000, "o", "[INFO] BUILD SUCCESS\r\n"]
[0.012, "o", "\r\n"]
[1.004, "o", "\u001b[0;32mSCENE 3: Code Change\u001b[0m\r\nNow I'll break the StringUtils.capitalize() method...\r\n\r\n"]
[0.011, "o", "Changed: StringUtils.capitalize() now returns empty string\r\n\r\nDiff:\r\n---\r\n"]
[0.012, "o", "diff --git a/test-order-example/src/main/java/com/example/app/StringUtils.java b/test-order-example/src/main/java/com/example/app/StringUtils.java\r\nindex b2fe0e5..dd60b27 100644\r\n--- a/test-order-example/src/main/java/com/example/app/StringUtils.java\r\n+++ b/test-order-example/src/main/java/com/example/app/StringUtils.java\r\n@@ -18,6 +18,7 @@ public class StringUtils {\r\n \r\n     public String capitalize(String input) {\r\n         if (input == null || input.isEmpty()) return input;\r\n-        return Character.toUpperCase(input.charAt(0)) + input.substring(1);\r\n+        // BREAKING CHANGE: Returns empty string instead of capitalizing\r\n+        return \"\";\r\n     }\r\n-}\r\n\\ No newline at end of file\r\n+}\r\n"]
[0.001, "o", "\r\n"]
[1.004, "o", "\u001b[0;32mSCENE 4: Reordered Tests After Change\u001b[0m\r\nTest-order recalculates the priority. StringUtilsTest moves to top with highest score.\r\n"]
[0.000, "o", "\r\n"]
[0.877, "o", "[INFO] Changed classes: [com.example.app.StringUtils]\r\n"]
[0.000, "o", "[INFO]   #    Test Class               Score  Deps  Fail  Changed Duration\r\n"]
[0.001, "o", "[INFO]   1.   c.e.app.StringUtilsTest      8     1                     7ms\r\n"]
[0.000, "o", "[INFO]   2.   c.e.app.CalculatorTest       0                          34ms\r\n"]
[0.000, "o", "[INFO] BUILD SUCCESS\r\n"]
[0.010, "o", "\r\n"]
[1.003, "o", "\u001b[0;32mSCENE 5: Fail-Fast Test Execution\u001b[0m\r\nRunning tests with intelligent ordering...\r\nStringUtilsTest runs FIRST and fails immediately.\r\n\r\n"]
[3.467, "o", "[ERROR] Tests run: 4, Failures: 1, Errors: 0, Skipped: 0, Time elapsed: 0.068 s <<< FAILURE! -- in com.example.app.StringUtilsTest\r\n[ERROR] com.example.app.StringUtilsTest.testCapitalize -- Time elapsed: 0.004 s <<< FAILURE!\r\n"]
[0.040, "o", "[ERROR] Tests run: 7, Failures: 1, Errors: 0, Skipped: 0\r\n"]
[0.022, "o", "\r\n"]
[1.008, "o", "\u001b[0;32mRestoring original code...\u001b[0m\r\n"]
[0.005, "o", "\r\n\u001b[0;32m=== Demo Complete ===\u001b[0m\r\n"]
[0.000, "o", "Key takeaway: Failures surfaced immediately thanks to intelligent test ordering.\r\n"]
