<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>me.bechberger.it</groupId>
    <artifactId>cross-module-select</artifactId>
    <version>1.0-SNAPSHOT</version>
  </parent>

  <artifactId>consumer</artifactId>

  <dependencies>
    <dependency>
      <groupId>me.bechberger.it</groupId>
      <artifactId>library</artifactId>
      <version>${project.version}</version>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter-api</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter-engine</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>@project.groupId@</groupId>
        <artifactId>@project.artifactId@</artifactId>
        <version>@project.version@</version>
        <extensions>true</extensions>
        <executions>
          <!--
            Phase 1 (learn): runs in mode=learn to build the dep index.
            Phase 2 (select): mode=learn is overridden by the second invoker run
            which passes -Dtestorder.mode=auto so prepare detects the existing
            index and switches to order mode; the separate 'affected' execution
            below activates in phase 2 via the 'select' profile.
          -->
          <execution>
            <id>prepare</id>
            <goals>
              <goal>prepare</goal>
            </goals>
            <configuration>
              <mode>learn</mode>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.2.5</version>
      </plugin>
    </plugins>
  </build>

  <!--
    'select' profile: activated in the second invoker run.
    Adds the 'affected' goal so test-order:affected filters Surefire's test list.
  -->
  <profiles>
    <profile>
      <id>select</id>
      <build>
        <plugins>
          <plugin>
            <groupId>@project.groupId@</groupId>
            <artifactId>@project.artifactId@</artifactId>
            <version>@project.version@</version>
            <executions>
              <execution>
                <id>prepare</id>
                <!-- Override the default learn execution: skip in select profile
                     (the affected goal below handles the selection). -->
                <configuration>
                  <skip>true</skip>
                </configuration>
              </execution>
              <execution>
                <id>select</id>
                <goals>
                  <goal>affected</goal>
                </goals>
                <configuration>
                  <!-- topN=-1: include all affected tests (no limit) -->
                  <topN>-1</topN>
                  <!-- randomM=0: no random padding so we can assert cleanly -->
                  <randomM>0</randomM>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
</project>
